BOT_TOKEN=your_bot_token
CHAT_ID=your_group_chat_id
SCAN_INTERVAL_SECONDS=30
FIRST_RUN_NOTIFY=false
RUN_ENV=local
CHROME_USER_DATA_DIR=/absolute/path/to/copied/chrome-user-data
