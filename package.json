{
  "name": "ebay-watcher",
  "version": "1.0.0",
  "description": "Watch multiple eBay seller pages and send Telegram alerts for new listings.",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env src/index.js",
    "start:once": "node --env-file=.env src/index.js --once",
    "telegram:test": "node --env-file=.env src/index.js --telegram-test",
    "cookies:refresh": "node --env-file=.env src/refresh-cookies.js",
    "cookies:print-header": "node --env-file=.env src/print-cookie-header.js",
    "check": "node --check src/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "playwright-core": "^1.58.2"
  }
}
